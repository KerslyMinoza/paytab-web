generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  passwordHash  String?  @map("password_hash")
  avatarUrl     String?  @map("avatar_url")
  emailVerified Boolean  @default(false) @map("email_verified")
  googleId      String?  @unique @map("google_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  groupMembers       GroupMember[]
  expensesPaid       Expense[]            @relation("PaidBy")
  expenseSplits      ExpenseSplit[]
  friendsInitiated   Friendship[]         @relation("FriendshipInitiator")
  friendsReceived    Friendship[]         @relation("FriendshipReceiver")
  settlements        Settlement[]         @relation("SettlementPayer")
  settlementsRecv    Settlement[]         @relation("SettlementPayee")
  refreshTokens      RefreshToken[]
  emailVerifications EmailVerification[]

  @@map("users")
}

model EmailVerification {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("email_verifications")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Friendship {
  id          String           @id @default(cuid())
  userId      String           @map("user_id")
  friendId    String?          @map("friend_id")
  friendEmail String?          @map("friend_email")
  localName   String?          @map("local_name")
  status      FriendshipStatus @default(PENDING_INVITE)
  createdAt   DateTime         @default(now()) @map("created_at")

  user   User? @relation("FriendshipInitiator", fields: [userId], references: [id], onDelete: Cascade)
  friend User? @relation("FriendshipReceiver", fields: [friendId], references: [id], onDelete: Cascade)

  inviteToken   InviteToken?
  pendingGroups PendingGroupMember[]

  @@unique([userId, friendId])
  @@unique([userId, friendEmail])
  @@map("friendships")
}

enum FriendshipStatus {
  PENDING_INVITE
  PENDING
  ACCEPTED
  BLOCKED
}

model InviteToken {
  id           String    @id @default(cuid())
  token        String    @unique
  friendshipId String    @unique @map("friendship_id")
  email        String
  expiresAt    DateTime  @map("expires_at")
  usedAt       DateTime? @map("used_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  friendship Friendship @relation(fields: [friendshipId], references: [id], onDelete: Cascade)

  @@map("invite_tokens")
}

model PendingGroupMember {
  id           String @id @default(cuid())
  friendshipId String @map("friendship_id")
  groupId      String @map("group_id")

  friendship Friendship @relation(fields: [friendshipId], references: [id], onDelete: Cascade)
  group      Group      @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([friendshipId, groupId])
  @@map("pending_group_members")
}

model Group {
  id        String   @id @default(cuid())
  name      String
  imageUrl  String?  @map("image_url")
  createdBy String   @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members        GroupMember[]
  expenses       Expense[]
  pendingMembers PendingGroupMember[]

  @@map("groups")
}

model GroupMember {
  id       String          @id @default(cuid())
  groupId  String          @map("group_id")
  userId   String          @map("user_id")
  role     GroupMemberRole @default(MEMBER)
  joinedAt DateTime        @default(now()) @map("joined_at")

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@map("group_members")
}

enum GroupMemberRole {
  ADMIN
  MEMBER
}

model Expense {
  id          String    @id @default(cuid())
  groupId     String    @map("group_id")
  description String
  amount      Decimal   @db.Decimal(12, 2)
  currency    String    @default("PHP")
  paidById    String    @map("paid_by_id")
  splitType   SplitType @default(EQUAL) @map("split_type")
  date        DateTime  @default(now())
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  group  Group          @relation(fields: [groupId], references: [id], onDelete: Cascade)
  paidBy User           @relation("PaidBy", fields: [paidById], references: [id])
  splits ExpenseSplit[]

  @@map("expenses")
}

enum SplitType {
  EQUAL
  EXACT
  PERCENTAGE
}

model ExpenseSplit {
  id        String  @id @default(cuid())
  expenseId String  @map("expense_id")
  userId    String  @map("user_id")
  amount    Decimal @db.Decimal(12, 2)

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([expenseId, userId])
  @@map("expense_splits")
}

model Settlement {
  id        String   @id @default(cuid())
  payerId   String   @map("payer_id")
  payeeId   String   @map("payee_id")
  amount    Decimal  @db.Decimal(12, 2)
  currency  String   @default("PHP")
  groupId   String?  @map("group_id")
  note      String?
  createdAt DateTime @default(now()) @map("created_at")

  payer User @relation("SettlementPayer", fields: [payerId], references: [id])
  payee User @relation("SettlementPayee", fields: [payeeId], references: [id])

  @@map("settlements")
}
